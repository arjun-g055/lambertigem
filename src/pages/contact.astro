---
import BaseLayout from "../layouts/BaseLayout.astro";
import Nav from "../components/navbar";
import Form from "../components/form.tsx";
---

<BaseLayout title="Contact Us">
    <div
        class="min-h-screen bg-black text-white relative font-sans w-full max-w-[100vw] overflow-x-hidden pb-20"
    >
        {/* Glow effects */}
        <div
            class="absolute bottom-[-10%] left-[-10%] w-[60%] h-[80%] bg-[#5A0A0A]/40 blur-[140px] rounded-full pointer-events-none z-0"
        >
        </div>

        <div class="relative z-20">
            <Nav />
        </div>

        <main
            class="max-w-[1400px] w-full mx-auto px-8 md:px-16 py-12 md:py-16 relative z-10 flex flex-col"
        >
            <h1
                class="text-4xl md:text-5xl font-bold text-center mb-16 md:mb-24 mt-8 tracking-tight font-sans"
            >
                Contact Us
            </h1>

            <div
                class="w-full grid md:grid-cols-[1fr_1.2fr] gap-12 md:gap-20 items-start mt-4"
            >
                {/* Left Column */}
                <div class="flex flex-col space-y-12">
                    <h2
                        class="text-5xl md:text-[3.5rem] font-bold leading-tight tracking-tight mb-2"
                    >
                        Tell us about your<br />story
                    </h2>

                    <div
                        class="flex flex-col gap-10 text-[#D1D1D1] text-lg mt-8"
                    >
                        <div class="flex items-center gap-6">
                            <img
                                src="https://gbditp38bksey5gu.public.blob.vercel-storage.com/greenLogo.png"
                                alt="Package"
                                class="w-12 h-12 object-contain"
                            />
                            <p>We will get back to you in 3-5 business days.</p>
                        </div>

                        <div class="flex items-center gap-6">
                            <img
                                src="https://gbditp38bksey5gu.public.blob.vercel-storage.com/silverLogo.png"
                                alt="Package"
                                class="w-12 h-12 object-contain"
                            />
                            <p>Send us some feedback!</p>
                        </div>

                        <div class="flex items-center gap-6">
                            <img
                                src="https://gbditp38bksey5gu.public.blob.vercel-storage.com/bluePink.png"
                                alt="Package"
                                class="w-12 h-12 object-contain"
                            />
                            <p>In the meantime, check out our other pages.</p>
                        </div>
                    </div>
                </div>

                {/* Right Column */}
                <div class="w-full flex justify-end pt-16">
                    <Form client:load />
                </div>
            </div>
        </main>
    </div>
</BaseLayout>
